package com.huawei.hr.hrpotal.emp.profile.common.configuration;

import com.huawei.it.jalor5.core.request.impl.RequestContext;
import com.huawei.it.jalor5.core.request.impl.RequestContextManager;

import org.slf4j.Logger;
import org.slf4j.LoggerFactory;
import org.springframework.core.task.TaskDecorator;

public class JalorContextDecorator implements TaskDecorator {
    private static final Logger log = LoggerFactory.getLogger(JalorContextDecorator.class);

    public JalorContextDecorator() {
    }

    public Runnable decorate(Runnable runnable) {
        String mainThreadName = getCurrentThreadName();
        RequestContext requestContext = (RequestContext) RequestContextManager.getCurrent(true);
        return () -> {
            try {
                RequestContextManager.setCurrent(requestContext);
                runnable.run();
            } catch (Exception exception) {
                log.error("decorate ctx...", exception);
            } finally {
                if (!getCurrentThreadName().equals(mainThreadName)) {
                    RequestContextManager.removeCurrent();
                }
            }
        };
    }

    public static String getCurrentThreadName() {
        return Thread.currentThread().getName() + "-" + Thread.currentThread().getId();
    }
}

