package com.huawei.hr.hrpotal.emp.profile.common.configuration;

import org.springframework.beans.factory.annotation.Value;
import org.springframework.context.annotation.Bean;
import org.springframework.context.annotation.Configuration;
import org.springframework.scheduling.annotation.EnableAsync;
import org.springframework.scheduling.concurrent.ThreadPoolTaskExecutor;

import java.util.concurrent.Executor;
import java.util.concurrent.ThreadPoolExecutor;

@Configuration
@EnableAsync
public class ExecutorConfiguration {
    @Value("${mobile.thread.max.capacity:50}")
    private int mobileMaxThreadCapacity;

    @Value("${mobile.thread.core.size:10}")
    private int mobileCorePoolSize;

    @Value("${mobile.thread.queue:200}")
    private int mobileThreadQueue;

    @Value("${parallel.thread.max.capacity:30}")
    private int parallelMaxThreadCapacity;

    @Value("${parallel.thread.core.size:10}")
    private int parallelCorePoolSize;

    @Value("${parallel.thread.queue:200}")
    private int parallelThreadQueue;

    @Bean("mobileExecutor")
    public Executor mobileExecutor() {
        ThreadPoolTaskExecutor executor = new ThreadPoolTaskExecutor();
        executor.setCorePoolSize(mobileCorePoolSize);
        executor.setMaxPoolSize(mobileMaxThreadCapacity);
        executor.setQueueCapacity(mobileThreadQueue);
        executor.setThreadNamePrefix("mobileExecutor-");
        executor.setRejectedExecutionHandler(new ThreadPoolExecutor.AbortPolicy());
        executor.setTaskDecorator(new JalorContextDecorator());
        executor.initialize();
        return executor;
    }

    @Bean("parallelExecutor")
    public Executor parallelExecutor() {
        ThreadPoolTaskExecutor executor = new ThreadPoolTaskExecutor();
        executor.setCorePoolSize(parallelCorePoolSize);
        executor.setMaxPoolSize(parallelMaxThreadCapacity);
        executor.setQueueCapacity(parallelThreadQueue);
        executor.setThreadNamePrefix("parallel-executor-");
        executor.setRejectedExecutionHandler(new ThreadPoolExecutor.CallerRunsPolicy());
        executor.setTaskDecorator(new JalorContextDecorator());
        executor.initialize();
        return executor;
    }
}
