    /**
     * 处理权限字段
     * <p>
     * 遍历 AuthPerson 枚举值，判断字段类别权限(使用按位与运算)，对于没权限的类别字段值置为 *
     */
    private void parsePagedResultResultAuthField(Map<String, Object> sourceMap, int authValue) {
        Arrays.stream(AuthPerson.values())
                .filter(ap -> (authValue & ap.getWeight()) == 0)
                .forEach(ap -> ap.getControlFields().stream()
                        .filter(sourceMap::containsKey)
                        .forEach(field -> sourceMap.put(field, NO_AUTH_FIELD_VALUE))
                );
    }


    
    /**
     * 异步组装模板数据
     */
    private TemplateCombinedDataDTO getTemplateCombinedData(TalentReviewQueryDTO talentReviewQueryDTO) {
        TemplateCombinedDataDTO templateCombinedDataDTO = new TemplateCombinedDataDTO();

        List<CompletableFuture> taskList = new ArrayList<>();
        // 1、分页查询指定模版审视表数据
        taskList.add(CompletableFuture.runAsync(() -> templateCombinedDataDTO.setTemplateData(getTemplateData(talentReviewQueryDTO)), asyncExecutor).whenComplete((r, e) -> {
            if (Objects.nonNull(e)) {
                log.error("---------------talentReview#getTemplateData error", e);
            }
        }));
        // 2、查询模板隐藏人员数量
        taskList.add(CompletableFuture.runAsync(() -> templateCombinedDataDTO.setEmpHideCount(getEmpHideCount(talentReviewQueryDTO)), asyncExecutor).whenComplete((r, e) -> {
            if (Objects.nonNull(e)) {
                log.error("---------------talentReview#queryEmpHideCount error", e);
            }
        }));
        // 3、获取审视列表头分组和列
        taskList.add(CompletableFuture.runAsync(() -> templateCombinedDataDTO.setHeadGroupAndColumnData(getHeadGroupAndColumn(talentReviewQueryDTO, false)), asyncExecutor).whenComplete((r, e) -> {
            if (Objects.nonNull(e)) {
                log.error("---------------talentReview#findHeadGroupAndColumn error", e);
            }
        }));
        // 获取返回结果
        taskList.stream().forEach(task -> {
            try {
                task.get(talentReviewTimeOut, TimeUnit.MILLISECONDS);
            } catch (Exception e) {
                log.error("---------------talentReview#getTemplateData query error-->", e);
            }
        });
        CompletableFuture.allOf(taskList.toArray(new CompletableFuture[0])).join();
        return templateCombinedDataDTO;
    }

